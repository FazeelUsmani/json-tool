{
  "name": "json-tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite-react-ssg build",
    "lint": "eslint .",
    "preview": "vite preview",
    "spike": "vite --open /spikes/",
    "bench:gen": "node benchmarks/generate.mjs",
    "bench:gen:all-dev": "node benchmarks/generate.mjs --all-dev",
    "gen:100k": "node benchmarks/generate.mjs --shape flat-array --size 100000",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright install --with-deps chromium && npm run build && playwright test"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "npm@10.5.0",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@streamparser/json": "^0.0.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "comlink": "^4.4.2",
    "immer": "^11.1.8",
    "jsonrepair": "^3.14.0",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-resizable-panels": "^4.11.1",
    "react-router-dom": "^6.30.3",
    "react-window": "^2.2.7",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^4.5.7"
  },
  "overrides": {
    "dompurify": "^3.4.5",
    "qs": "^6.15.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-react-ssg": "^0.9.1-beta.1",
    "vitest": "^4.1.6"
  }
}
